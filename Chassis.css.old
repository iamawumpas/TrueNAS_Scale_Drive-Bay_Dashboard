/* Chassis.css */

.storage-unit { 
    background-color: var(--chassis-bg-base);
    background-image: 
        url("data:image/svg+xml,%3Csvg width='100' height='100' xmlns='http://www.w3.org/2000/svg'%3E%3Cdefs%3E%3ClinearGradient id='scratch' x1='0%' y1='0%' x2='100%' y2='0%'%3E%3Cstop offset='0%' style='stop-color:rgba(255,255,255,0);stop-opacity:1' /%3E%3Cstop offset='50%' style='stop-color:rgba(255,255,255,0.15);stop-opacity:1' /%3E%3Cstop offset='100%' style='stop-color:rgba(255,255,255,0);stop-opacity:1' /%3E%3C/linearGradient%3E%3C/defs%3E%3Cline x1='5' y1='10' x2='25' y2='15' stroke='url(%23scratch)' stroke-width='0.5' opacity='var(--chassis-scratch-opacity, 0.3)' /%3E%3Cline x1='35' y1='20' x2='55' y2='18' stroke='url(%23scratch)' stroke-width='0.5' opacity='var(--chassis-scratch-opacity, 0.3)' /%3E%3Cline x1='65' y1='12' x2='85' y2='22' stroke='url(%23scratch)' stroke-width='0.5' opacity='var(--chassis-scratch-opacity, 0.3)' /%3E%3Cline x1='15' y1='40' x2='35' y2='42' stroke='url(%23scratch)' stroke-width='0.5' opacity='var(--chassis-scratch-opacity, 0.3)' /%3E%3Cline x1='45' y1='35' x2='70' y2='45' stroke='url(%23scratch)' stroke-width='0.5' opacity='var(--chassis-scratch-opacity, 0.3)' /%3E%3Cline x1='75' y1='38' x2='95' y2='40' stroke='url(%23scratch)' stroke-width='0.5' opacity='var(--chassis-scratch-opacity, 0.3)' /%3E%3Cline x1='10' y1='65' x2='30' y2='68' stroke='url(%23scratch)' stroke-width='0.5' opacity='var(--chassis-scratch-opacity, 0.3)' /%3E%3Cline x1='40' y1='60' x2='65' y2='70' stroke='url(%23scratch)' stroke-width='0.5' opacity='var(--chassis-scratch-opacity, 0.3)' /%3E%3Cline x1='70' y1='62' x2='90' y2='65' stroke='url(%23scratch)' stroke-width='0.5' opacity='var(--chassis-scratch-opacity, 0.3)' /%3E%3Cline x1='20' y1='85' x2='40' y2='90' stroke='url(%23scratch)' stroke-width='0.5' opacity='var(--chassis-scratch-opacity, 0.3)' /%3E%3Cline x1='55' y1='80' x2='75' y2='88' stroke='url(%23scratch)' stroke-width='0.5' opacity='var(--chassis-scratch-opacity, 0.3)' /%3E%3Cline x1='80' y1='75' x2='100' y2='82' stroke='url(%23scratch)' stroke-width='0.5' opacity='var(--chassis-scratch-opacity, 0.3)' /%3E%3C/svg%3E"),
        repeating-linear-gradient(rgba(255,255,255,0.03) 0px, rgba(255,255,255,0.03) 1px, transparent 1px, transparent 2px);
    background-size: auto, 100% 100%;
    border: 1px solid var(--chassis-border); 
    padding: 10px; 
    border-radius: 8px; 
    box-shadow: inset 0 0 20px #000, 0 10px 30px var(--chassis-shadow);
    display: block;
    width: var(--rack-chassis-width);   /* 17.5 in — standard rack-mount metal enclosure */
    max-width: calc(100vw - 32px);
    box-sizing: border-box;
    margin: 15px auto 15px auto;
    position: relative;
    overflow: hidden;
}

/* Vertical single-column layout: even spacing on all sides */
@media (max-width: 1500px) {
    .storage-unit {
        margin: 15px auto 15px auto;
    }
}

/* Masonry multi-column layout: reduce gap by 50% */
@media (min-width: 1501px) {
    .storage-unit {
        margin: 6.25px auto 6.25px auto;
}

.chassis-inner {
    position: relative;
    overflow: visible;
    z-index: 0;
}

.chassis-inner > * {
    position: relative;
    z-index: 1;
}

/* Flare Effect - renders across entire chassis including bays */
.chassis-inner::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 5;
    mix-blend-mode: screen;
    will-change: transform, opacity;
    
    /* Radial gradient positioned at offset coordinates */
    background: radial-gradient(
        circle at var(--flare-offset-x, 10%) var(--flare-offset-y, 10%),
        rgba(255, 255, 255, var(--flare-opacity, 0.15)) 0%,
        rgba(255, 255, 255, 0) var(--flare-spread, 10%)
    );
    
    /* Transform with rotation and scale */
    transform: rotate(var(--flare-angle, 30deg)) scale(var(--flare-size, 1));
}

.chassis-header {
    display: flex;
    align-items: flex-end;
    padding: 10px 10px 20px 10px;
    border-bottom: 1px solid var(--chassis-header-divider);
}

.header-left {
    display: flex;
    flex-direction: column;
    min-width: 0;
}

.hostname { 
    color: var(--server-name-color); 
    font-family: var(--server-name-font); 
    font-size: calc(var(--server-name-size) * var(--server-name-scale, 1)); 
    font-weight: var(--server-name-weight); 
    font-style: var(--server-name-style);
    text-transform: var(--server-name-transform); 
    margin: 0;
    line-height: 0.9;
}

.pci-address-grey { 
    color: var(--pci-address-color); 
    font-family: var(--pci-address-font); 
    font-size: calc(var(--pci-address-size) * var(--pci-address-scale, 1)); 
    font-weight: var(--pci-address-weight);
    font-style: var(--pci-address-style);
    text-transform: var(--pci-address-transform);
    margin-top: 5px;
}

/* Standalone Legend Chassis */
#legend-chassis {
    --legend-scale: 1;
    background-color: #1a1a1a;
    background-image:
        repeating-linear-gradient(rgba(255,255,255,0.03) 0px, rgba(255,255,255,0.03) 1px, transparent 1px, transparent 2px),
        linear-gradient(115deg, #111 0%, #222 30%, #333 45%, #222 60%, #111 100%);
    border: 1px solid #333;
    padding: 20px;
    border-radius: 12px;
    box-shadow: inset 0 0 20px #000, 0 10px 30px rgba(0,0,0,0.8);
    display: flex;
    flex-direction: column;
    align-self: stretch;
    min-width: 200px;
    justify-content: center;
}

#legend-chassis .legend-title {
    font-size: 1.1rem;
    letter-spacing: 1px;
    margin-bottom: 14px;
}

/* Inline legend-box still used within chassis headers if needed */
.legend-box {
    display: none;
}

.legend-title {
    color: var(--legend-title-color);
    font-size: 0.7rem;
    font-family: var(--legend-font);
    font-weight: var(--legend-weight);
    font-style: var(--legend-style);
    text-transform: var(--legend-transform);
    letter-spacing: 0.5px;
    margin-bottom: 6px;
}

/* Grid Layout: 2 Columns */
.legend-items-row {
    display: grid;
    grid-template-columns: repeat(2, auto);
    column-gap: calc(20px * var(--legend-scale));
    row-gap: calc(10px * var(--legend-scale));
    width: max-content;
}

.legend-item {
    display: flex;
    align-items: center;
    gap: calc(8px * var(--legend-scale));
    color: var(--legend-color);
    font-size: calc(var(--legend-size) * var(--legend-scale));
    font-family: var(--legend-font);
    font-weight: var(--legend-weight);
    font-style: var(--legend-style);
    text-transform: var(--legend-transform);
    white-space: nowrap;
}

/* Dots Styling */
.dot {
    height: calc(10px * var(--legend-scale));
    width: calc(10px * var(--legend-scale));
    border-radius: 50%;
    display: inline-block;
}

.green { background-color: var(--led-allocated-healthy); box-shadow: 0 0 8px var(--led-allocated-healthy); }
.allocated-offline { background-color: var(--led-allocated-offline); }
.orange { background-color: var(--led-error); box-shadow: 0 0 8px var(--led-error); }
.red { background-color: var(--led-faulted); box-shadow: 0 0 8px var(--led-faulted); }
.white { background-color: var(--led-resilvering); box-shadow: 0 0 8px var(--led-resilvering); }
.purple { background-color: var(--led-unallocated); box-shadow: 0 0 8px var(--led-unallocated); }

/* Border-only dots for Unallocated Errors/Faults */
.unalloc-error { border: 2px solid var(--led-unalloc-error); background: transparent; }
.unalloc-fault { border: 2px solid var(--led-unalloc-fault); background: transparent; }

.capacity-warning {
    display: none;
    margin-top: 16px;
    padding: 10px 12px;
    border: 1px solid rgba(255, 170, 0, 0.6);
    background: rgba(255, 170, 0, 0.08);
    color: var(--bay-id-color);
    font-size: 0.85rem;
    letter-spacing: 0.3px;
}

/* Keep inter-chassis spacing, but tighten final chassis to sit close to wrapper bottom */
.storage-unit:last-child {
    margin-bottom: 5px;
}